# Capfire server environment — rendered by scripts/install-server.sh into
# /etc/capfire/env and loaded by systemd via `EnvironmentFile=`.
#
# Values marked "[generated]" were produced automatically at install time.
# Values marked "[required]" must be filled in before starting the service.
# Everything else is optional with sensible defaults.

# --- required ------------------------------------------------------------
RAILS_ENV=production

# HMAC secret used to sign API tokens. NEVER share across nodes or commit.
CAPFIRE_JWT_SECRET=__JWT_SECRET__

# Postgres connection string. Capfire expects a DB it fully owns.
#   Example: postgres://capfire:pass@localhost:5432/capfire_production
DATABASE_URL=__DATABASE_URL__

# --- optional ------------------------------------------------------------

# Root directory where cloned apps live. `capfire project add` places new
# apps under $CAPFIRE_APPS_ROOT/<name>.
CAPFIRE_APPS_ROOT=__APPS_ROOT__

# Comma-separated allowlist of apps this node may deploy. Empty => any.
# CAPFIRE_ALLOWED_APPS=myapp,myapp-api

# Base URL returned in async deploy track URLs. Defaults to request.base_url.
# CAPFIRE_PUBLIC_URL=https://capfire.example.com

# Cloudflare API token used for LB drain/restore (per-app config lives in
# each app's capfire.yml). Leave unset if you don't use Cloudflare LBs.
# CF_API_TOKEN=

# Default Slack webhook (per-app override via capfire.yml `slack.webhook_env`).
# SLACK_WEBHOOK_URL=

# Puma tuning — defaults are fine for most deployments.
# RAILS_MAX_THREADS=16
# PORT=3000
