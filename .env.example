# Capfire environment variables (example)
# Copy to .env and fill with real values. NEVER commit the real .env.

# --- Rails ---
RAILS_ENV=development
PORT=3000
SECRET_KEY_BASE=change-me-with-rails-secret

# --- JWT signing ---
# Used to sign and verify API tokens. Rotate with care.
CAPFIRE_JWT_SECRET=replace-with-long-random-string

# --- Database ---
DATABASE_URL=postgres://capfire:capfire@localhost:5432/capfire_development

# --- Runtime ---
# Absolute path to the working directory where deploy commands run.
# Each app can override with CAPFIRE_APP_DIR_<APP_SLUG>.
CAPFIRE_APPS_ROOT=/srv/apps

# Optional: comma-separated list of apps this node is allowed to deploy.
# Empty/unset means any app allowed by the token.
CAPFIRE_ALLOWED_APPS=

# Optional: public base URL of this Capfire instance (used to build the
# `track_url` field in async responses). Leave empty and we'll fall back to
# Rails' request.base_url. Set this if Capfire runs behind a proxy that
# rewrites Host/Forwarded headers.
# Example: CAPFIRE_PUBLIC_URL=https://capfire.example.com
CAPFIRE_PUBLIC_URL=

# --- Cloudflare Load Balancer ---
# Only the API token is global (secret). The pool, account and origin live
# per-app inside the app's capfire.yml (see README).
# Scope: Zone:Load Balancers:Edit + Account:Load Balancers:Edit
CF_API_TOKEN=

# --- Slack notifications (optional) ---
# Incoming Webhook URL used when an app opts in via `slack.enabled: true` in
# its capfire.yml. A single channel receives all apps by default; override
# per-app with a different env var name via `slack.webhook_env` in the yml.
SLACK_WEBHOOK_URL=
